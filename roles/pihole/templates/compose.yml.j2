services:
  pihole:
    image: "ghcr.io/pi-hole/pihole:{{ pihole_version_tag }}"
    restart: unless-stopped
    network_mode: host
    environment:
      TZ: "{{ timezone }}"
      FTLCONF_webserver_api_password: "go"
      FTLCONF_dns_listeningMode: "ALL"
      FTLCONF_dns_upstreams: "{{ dns1 }};{{ dns2 }}"
    volumes:
      - "{{ container_compose_dir }}/conf:/etc/pihole"
      - "{{ container_compose_dir }}/conf/dnsmasq.d:/etc/dnsmasq.d"
